{
  "name": "clihub-monorepo",
  "version": "1.72.0",
  "private": true,
  "description": "clihub — install Claude Code, Codex, Gemini, Qwen Code, Kiro, Cursor & Goose and keep their skills in sync",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test packages/core/test packages/daemon/test",
    "test:install": "bash scripts/test-install.sh",
    "cli": "bun packages/cli/src/cli.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.10.0"
  },
  "engines": {
    "node": ">=18"
  }
}
