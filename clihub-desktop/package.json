{
  "name": "clihub-desktop",
  "version": "1.68.0",
  "private": true,
  "type": "module",
  "description": "clihub desktop GUI (Tauri 2 + Svelte 5) — binds to the @clihub/daemon sidecar",
  "scripts": {
    "dev": "vite",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "test": "vitest run",
    "tauri": "tauri"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^5.0.3",
    "@tauri-apps/api": "^2.1.1",
    "@tauri-apps/cli": "^2.11.2",
    "svelte": "^5.19.0",
    "svelte-check": "^4.1.4",
    "typescript": "^5.6.3",
    "vite": "^6.0.7",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/ibm-plex-sans": "^5.2.8"
  }
}
