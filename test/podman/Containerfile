# clihub TEST environment — REAL AI CLIs, no stubs.
#
# Installs clihub plus the actual Claude Code / Gemini / Codex CLIs from npm
# (installing them needs no login — only running a *session* does). So `doctor`,
# `proxy`, `skill`, `mcp`, `config` operate on real binaries and real config
# files (~/.claude, ~/.gemini, ~/.codex). Runs as root so `clihub tool install`
# and ad-hoc `npm i -g` work without sudo.
#
#   podman build -t clihub-test test/podman
#   podman run --rm clihub-test /opt/report.sh    # automated real-CLI report
#   podman run --rm -it clihub-test bash          # interactive: clihub wizard / TUI
#
# Distinct from the root ./Dockerfile (that is the end-user distribution image).
FROM docker.io/library/node:20

ARG CLIHUB_VERSION=latest

# clihub + the three real CLIs it manages. node:20 already ships git/curl/bash.
RUN npm install -g \
      @wikieden/clihub@${CLIHUB_VERSION} \
      @anthropic-ai/claude-code \
      @google/gemini-cli \
      @openai/codex \
  && echo "=== installed, real --version ===" \
  && clihub --version \
  && claude --version \
  && gemini --version \
  && codex --version

COPY report.sh /opt/report.sh
RUN chmod +x /opt/report.sh

ENV CLIHUB_NO_NUDGE=1
WORKDIR /root
CMD ["bash"]
