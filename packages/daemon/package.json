{
  "name": "@clihub/daemon",
  "version": "1.73.0",
  "private": true,
  "description": "clihub daemon: thin Bun HTTP sidecar — 1:1 kernel route table, the only IPC surface for the desktop GUI (workspace-only, not published)",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./routes": "./src/routes.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc"
  },
  "files": [
    "src",
    "dist"
  ],
  "devDependencies": {
    "@clihub/core": "workspace:*",
    "bun-types": "^1.1.0"
  }
}
