{
  "name": "clihub",
  "version": "0.1.0",
  "description": "clihub — cross-platform AI CLI toolkit manager",
  "type": "module",
  "bin": {
    "clihub": "./dist/cli.js"
  },
  "main": "./dist/cli.js",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "bun run build:bundle && bun run build:chmod",
    "build:bundle": "bun build --target node --bundle --outfile dist/cli.js src/cli.ts",
    "build:chmod": "chmod +x dist/cli.js",
    "start": "bun src/cli.ts",
    "prepublishOnly": "bun run build"
  },
  "dependencies": {
    "@clihub/core": "workspace:*",
    "cac": "^6.7.14",
    "@clack/prompts": "^0.8.2",
    "kleur": "^4.1.5"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": ["claude-code", "ai", "cli", "skill", "codex", "kiro"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wikieden/clihub.git"
  }
}
